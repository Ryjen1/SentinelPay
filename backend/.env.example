BACKEND_URL=http://127.0.0.1:8000
OPENAI_API_KEY=your_openai_api_key_here

# Blockchain (Celo Sepolia defaults)
CELO_RPC=https://celo-sepolia.g.alchemy.com/v2/YOUR_API_KEY
CHAIN_ID=11142220
NETWORK_NAME=Celo Sepolia
NETWORK_LABEL=Celo Sepolia Testnet
EXPLORER_TX_BASE_URL=https://sepolia.celoscan.io/tx

PRIVATE_KEY=your_operator_wallet_private_key
AGENT_VAULT_ADDRESS=0xYourAgentVaultAddress
USDC_ADDRESS=0xYourUsdcAddress
PAYMENT_TOKEN_SYMBOL=USDC

# PolicyRegistry (used for auto-register / auto-activation)
POLICY_REGISTRY_ADDRESS=0xYourPolicyRegistryAddress
DEFAULT_MAX_PER_TX_USDC=1.0
DEFAULT_DAILY_CAP_USDC=5.0

# Pricing / defaults
DEFAULT_AGENT_ID=weather_agent
DEFAULT_RECIPIENT=0x61254AEcF84eEdb890f07dD29f7F3cd3b8Eb2CBe
WEATHER_PRICE_USDC=0.5
DATA_FEED_PRICE_USDC=1.0
DEMO_EXECUTION_AMOUNT_USDC=0.50

# Live market data (optional)
LIVE_MARKET_DATA=false
MARKET_DATA_TIMEOUT_SECONDS=6

# Live weather data (optional)
LIVE_WEATHER_DATA=false
WEATHER_CITY=Bangalore
# Optional: bypass geocoding and pin coordinates directly
WEATHER_LATITUDE=
WEATHER_LONGITUDE=
WEATHER_DATA_TIMEOUT_SECONDS=6

# Production hardening flags
REQUIRE_WALLET_SIGNATURE=false
WALLET_SIGNATURE_MAX_SKEW_SECONDS=300
REQUIRE_OPERATOR_AUTH=false
OPERATOR_API_KEYS=replace_me_with_long_random_key
# Optional single key used by local agent scripts/SDK
OPERATOR_API_KEY=replace_me_with_one_of_operator_keys
REQUIRE_IDEMPOTENCY_KEY=false
REQUIRE_AGENT_SIGNATURE=false
AGENT_SHARED_SECRET=replace_me_with_long_random_secret
AGENT_SIGNATURE_MAX_SKEW_SECONDS=300

# Queue / worker controls
PAYMENT_WORKER_ENABLED=true
PAYMENT_JOB_MAX_ATTEMPTS=3
PAYMENT_JOB_RETRY_BASE_SECONDS=2
PAYMENT_JOB_WAIT_TIMEOUT_SECONDS=120
PAYMENT_WORKER_POLL_MS=400
